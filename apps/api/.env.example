NODE_ENV=development
HOST=0.0.0.0
PORT=4000
# Preferred for hosted environments. Comma-separated list of allowed frontend origins.
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Backward-compatible single-origin fallback used by older local configs.
FRONTEND_ORIGIN=http://localhost:5173
TRUST_PROXY=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aegis_core?schema=public
JWT_SECRET=change-this-before-deploying
JWT_EXPIRES_IN=8h
JWT_ISSUER=aegis-core
LOG_LEVEL=info
AI_ANALYZER_PROVIDER=mock
AI_ALERT_THRESHOLD=80
AI_EXTERNAL_SERVICE_URL=
AI_EXTERNAL_SERVICE_API_KEY=
AI_EXTERNAL_SERVICE_TIMEOUT_MS=8000
