generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ANALYST
  RESPONDER
}

enum LogSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum LogEventType {
  AUTHENTICATION
  PROCESS_EXECUTION
  NETWORK_TRAFFIC
  EMAIL_SECURITY
  PRIVILEGE_CHANGE
  FILE_ACTIVITY
  CLOUD_AUDIT
}

enum LogStatus {
  NEW
  REVIEWED
  INVESTIGATING
  ARCHIVED
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  NEW
  INVESTIGATING
  ESCALATED
  RESOLVED
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  CONTAINED
  RESOLVED
  CLOSED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id                String     @id @default(cuid())
  fullName          String
  email             String     @unique
  passwordHash      String
  role              UserRole   @default(ANALYST)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  createdIncidents  Incident[] @relation("IncidentCreator")
  assignedIncidents Incident[] @relation("IncidentAssignee")
}

model Log {
  id        String       @id @default(cuid())
  timestamp DateTime     @default(now())
  source    String
  host      String
  severity  LogSeverity  @default(INFO)
  eventType LogEventType @default(AUTHENTICATION)
  message   String
  rawData   Json?
  status    LogStatus    @default(NEW)
  createdAt DateTime     @default(now())
  alerts    Alert[]

  @@index([timestamp])
  @@index([severity, timestamp])
  @@index([source])
  @@index([host])
  @@index([eventType])
  @@index([status])
}

model Alert {
  id              String        @id @default(cuid())
  title           String
  description     String
  source          String
  severity        AlertSeverity @default(MEDIUM)
  status          AlertStatus   @default(NEW)
  confidenceScore Int           @default(75)
  linkedLogId     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  incident        Incident?     @relation("AlertIncident")
  linkedLog       Log?          @relation(fields: [linkedLogId], references: [id])

  @@index([severity, status])
  @@index([source])
  @@index([createdAt])
  @@index([linkedLogId])
}

model Incident {
  id             String           @id @default(cuid())
  reference      String           @unique
  title          String
  description    String
  severity       IncidentSeverity @default(MEDIUM)
  status         IncidentStatus   @default(OPEN)
  assigneeId     String?
  relatedAlertId String?          @unique
  createdById    String
  openedAt       DateTime         @default(now())
  closedAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  assignee       User?            @relation("IncidentAssignee", fields: [assigneeId], references: [id])
  relatedAlert   Alert?           @relation("AlertIncident", fields: [relatedAlertId], references: [id])
  createdBy      User             @relation("IncidentCreator", fields: [createdById], references: [id])

  @@index([severity, status])
  @@index([assigneeId])
  @@index([openedAt])
}
