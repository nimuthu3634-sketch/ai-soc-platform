{
  "name": "aegis-core",
  "version": "0.1.0",
  "private": true,
  "description": "AI-Integrated SOC for Automated Threat Detection and Response",
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,yellow \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm run dev -w @aegis-core/web",
    "dev:api": "npm run dev -w @aegis-core/api",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:start": "npm run db:start -w @aegis-core/api",
    "prisma:generate": "npm run prisma:generate -w @aegis-core/api",
    "prisma:migrate:dev": "npm run prisma:migrate:dev -w @aegis-core/api",
    "prisma:migrate:deploy": "npm run prisma:migrate:deploy -w @aegis-core/api",
    "prisma:seed": "npm run seed -w @aegis-core/api",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down -v"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.13.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  }
}
